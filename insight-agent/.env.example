# InsightAgent — environment variable template
# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as documentation.

# ── Required ──────────────────────────────────────────────────────────────────

# DeepSeek API key  (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ── Optional (override defaults) ──────────────────────────────────────────────

# Ollama base URL — default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Chat-memory storage directory — default: ./chat-memory (relative to working dir)
# APP_MEMORY_DIR=./chat-memory
